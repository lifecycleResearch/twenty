# ─── Vercel + Supabase deployment environment variables ───────────────────────
#
# Copy these into your Vercel project's Environment Variables settings.
# Values marked REQUIRED must be set before deployment.
# See: https://vercel.com/docs/environment-variables
#
# ─── Database (Supabase) ──────────────────────────────────────────────────────
#
# Use the Transaction pooler URL for serverless functions (port 6543).
# Found in: Supabase Dashboard > Project Settings > Database > Connection pooling
#
PG_DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Required for migrations / direct connections (non-pooled, port 5432):
# PG_DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].supabase.com:5432/postgres
#
# Supabase uses self-signed SSL in some configurations:
PG_SSL_ALLOW_SELF_SIGNED=true

# ─── Cache / Sessions (Upstash Redis) ─────────────────────────────────────────
#
# Upstash provides a serverless Redis compatible with Vercel.
# Create a database at: https://console.upstash.com
# Use the rediss:// (TLS) URL from the Upstash console.
#
REDIS_URL=rediss://:[password]@[endpoint].upstash.io:6379

# ─── App secrets (REQUIRED) ───────────────────────────────────────────────────

NODE_ENV=production
APP_SECRET=replace_me_with_a_random_string_at_least_32_chars

# ─── URLs (REQUIRED) ──────────────────────────────────────────────────────────
#
# Set SERVER_URL to your Vercel deployment URL (with https://).
# Set FRONTEND_URL to the same URL (single-domain deployment).
#
SERVER_URL=https://your-project.vercel.app
FRONTEND_URL=https://your-project.vercel.app

# ─── Frontend build variable ──────────────────────────────────────────────────
#
# Must match SERVER_URL so the React app knows where to reach the API.
# Set this as a Vercel Environment Variable (not just a .env file) so
# it is available at build time.
#
REACT_APP_SERVER_BASE_URL=https://your-project.vercel.app

# ─── Storage ──────────────────────────────────────────────────────────────────
#
# Local storage does not persist on Vercel. Use S3-compatible object storage
# (e.g. Supabase Storage, AWS S3, Cloudflare R2).
#
# STORAGE_TYPE=s3
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_NAME=your-bucket
# STORAGE_S3_ENDPOINT=           # leave blank for AWS S3
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# ─── Optional ─────────────────────────────────────────────────────────────────

# IS_WORKSPACE_CREATION_LIMITED_TO_SERVER_ADMINS=false
# AUTH_PASSWORD_ENABLED=true
# SIGN_IN_PREFILLED=false
# IS_MULTIWORKSPACE_ENABLED=false

# AUTH_GOOGLE_ENABLED=false
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_CALLBACK_URL=https://your-project.vercel.app/auth/google/redirect

# AUTH_MICROSOFT_ENABLED=false
# AUTH_MICROSOFT_CLIENT_ID=
# AUTH_MICROSOFT_CLIENT_SECRET=
# AUTH_MICROSOFT_CALLBACK_URL=https://your-project.vercel.app/auth/microsoft/redirect

# EMAIL_DRIVER=LOGGER   # use SMTP for real email delivery
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=
# EMAIL_FROM_ADDRESS=noreply@yourdomain.com
