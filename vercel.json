{
  "version": 2,
  "framework": null,
  "buildCommand": "echo 'Using pre-built artifacts'",
  "outputDirectory": "packages/twenty-front/build",
  "installCommand": "npm install -g corepack && corepack enable && yarn install",
  "build": {
    "env": {
      "REACT_APP_SERVER_BASE_URL": "https://twenty-crm.vercel.app"
    }
  },
  "env": {
    "IS_CONFIG_VARIABLES_IN_DB_ENABLED": "false"
  },
  "functions": {
    "api/index.js": {
      "memory": 2048,
      "maxDuration": 60,
      "includeFiles": "packages/twenty-server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/graphql", "destination": "/api/index.js" },
    { "source": "/metadata", "destination": "/api/index.js" },
    { "source": "/auth/:path*", "destination": "/api/index.js" },
    { "source": "/file/:path*", "destination": "/api/index.js" },
    { "source": "/healthz", "destination": "/api/index.js" },
    { "source": "/open-api/:path*", "destination": "/api/index.js" },
    { "source": "/engine/:path*", "destination": "/api/index.js" },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
